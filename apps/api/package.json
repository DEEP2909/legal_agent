{
  "name": "@legal-agent/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "dev:worker": "tsx watch src/worker-main.ts",
    "build": "tsc -p tsconfig.json",
    "lint": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "start": "node dist/index.js",
    "start:worker": "node dist/worker-main.js",
    "migrate": "node-pg-migrate up -m ../../db/migrations",
    "migrate:down": "node-pg-migrate down -m ../../db/migrations",
    "migrate:create": "node-pg-migrate create -m ../../db/migrations"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.901.0",
    "@fastify/cookie": "^11.0.1",
    "@fastify/cors": "^10.0.1",
    "@fastify/csrf-protection": "^7.0.1",
    "@fastify/formbody": "^8.0.2",
    "@fastify/helmet": "^13.0.0",
    "@fastify/multipart": "^9.0.3",
    "@fastify/rate-limit": "^10.3.0",
    "@legal-agent/shared": "0.1.0",
    "@node-saml/node-saml": "^5.1.0",
    "@opentelemetry/auto-instrumentations-node": "^0.56.1",
    "@opentelemetry/exporter-trace-otlp-http": "^0.214.0",
    "@opentelemetry/sdk-node": "^0.214.0",
    "@simplewebauthn/server": "^13.3.0",
    "fastify": "^5.0.0",
    "jose": "^5.9.6",
    "jsonwebtoken": "^9.0.2",
    "node-pg-migrate": "^8.0.4",
    "nodemailer": "^8.0.4",
    "openai": "^4.104.0",
    "otpauth": "^9.5.0",
    "pg": "^8.13.1",
    "qs": "^6.13.0",
    "unpdf": "^1.4.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/jsonwebtoken": "^9.0.8",
    "@types/nodemailer": "^7.0.11",
    "@types/pg": "^8.11.10",
    "@types/qs": "^6.9.17",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^4.1.2"
  }
}
